<odoo>

    <record id="l10n_latam_base_view_l10n_latam_identification_type_tree" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="l10n_latam_base.action_l10n_latam_identification_type" />
        <field name="view_id" ref="l10n_latam_base.view_l10n_latam_identification_type_tree" />
        <field name="view_mode">tree</field>
    </record>   
    
    <record id="view_l10n_latam_identification_type_form" model="ir.ui.view">
        <field name="name">Tipo de identificaciones</field>
        <field name="model">l10n_latam.identification.type</field>
        <field name="arch" type="xml">
            <form string="tag">
                <sheet>
                    <label for="name" class="oe_edit_only" />
                    <h1>
                        <field name="name" />
                    </h1>
                    <group>
                        <group>
                            <field name="description" />
                            <field name="country_id" />
                            <field name="webcheckout_is_default" />
                        </group>
                        <group>
                            <field name="active" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_latam_identification_type_tree_inherit" model="ir.ui.view">
        <field name="name">l10n_latam.identification.type.tree.inherit</field>
        <field name="model">l10n_latam.identification.type</field>
        <field name="inherit_id" ref="l10n_latam_base.view_l10n_latam_identification_type_tree"/>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="before">
                 <field name="webcheckout_is_default"/>                   
            </xpath>
            <xpath expr="//tree" position="attributes">
                <attribute name="edit">1</attribute>    
                <attribute name="create">1</attribute> 
            </xpath>
        </field>
    </record>

    <record id="l10n_latam_base_view_l10n_latam_identification_type_tree" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="l10n_latam_base.action_l10n_latam_identification_type" />
        <field name="view_id" ref="website_checkout_sunat.view_l10n_latam_identification_type_form" />
        <field name="view_mode">form</field>
    </record>

</odoo>