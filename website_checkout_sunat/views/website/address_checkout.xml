<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="address_b2b_inherit" inherit_id="website_sale.address_b2b">

    <label for="vat" position="before">
        <label for="l10n_latam_identification_type_id">Tipo Documento</label>
        <input name="l10n_latam_identification_type_id" id="l10n_latam_identification_type_id" class="l10n_latam_identification_type_id form-control "/>
    </label>

    <label for="vat" position="replace">
      <label for="vat">Número</label>
    </label>    

    <xpath expr='//div[@class="form-row"]' position='before'>
      <div class="form-row">
        <div class="form-group  col-lg-6 div_vat_type mb-0">
          <label for="l10n_latam_identification_type_id">Tipo Documento</label>
          <input name="l10n_latam_identification_type_id" id="l10n_latam_identification_type_id" class="l10n_latam_identification_type_id form-control "/>
        </div>
        <div class="form-group  col-lg-6 div_vat mb-0">
          <label for="vat">Número</label>
          <input type="text" name="vat" t-attf-class="form-control #{error.get('vat') and 'is-invalid' or ''}" t-att-value="'vat' in checkout and checkout['vat']" t-att-readonly="'1' if vat_warning else None"/>
        </div>
      </div>
    </xpath>

  </template>


  <template id="address_inherit" inherit_id="website_sale.address">

    <xpath expr="//div[@class='w-100'][last()]" position="before">

      <div class="form-group col-lg-6">
        <label for="city_id">Provincia</label>
        <input name="city_id" id="city_id" class="city_id form-control"/>
      </div>

      <div class="form-group col-lg-6">
        <label for="l10n_pe_district">Districto</label>
        <input name="l10n_pe_district" id="l10n_pe_district" class="l10n_pe_district form-control"/>
      </div>

      <div class="form-group">
        <label class="col-form-label label-optional" for="zip">Código Postal</label>
        <input type="text" name="zip" t-attf-class="form-control" t-att-value="'zip' in checkout and checkout['zip']"/>
      </div>

    </xpath>

  </template>

</odoo>